# GradeWise AI Environment Configuration

# App
APP_NAME=GradeWiseAI
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-me-in-production-to-secure-random-string
API_V1_PREFIX=/api/v1

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=gradewise
POSTGRES_USER=gradewise_user
POSTGRES_PASSWORD=gradewise_secure_password
DATABASE_URL=postgresql+asyncpg://gradewise_user:gradewise_secure_password@localhost:5432/gradewise

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET_KEY=change-jwt-secret-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ML
ML_MODELS_DIR=/app/ml/models/saved
ML_FEATURE_STORE_PATH=/app/ml/data/features
ML_EXPERIMENT_TRACKING=local

# Monitoring
PROMETHEUS_ENABLED=true
GRAFANA_ENABLED=true

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
NEXT_PUBLIC_APP_NAME=GradeWise AI
